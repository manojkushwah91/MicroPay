## MicroPay production environment (example)
## Copy to `.env` and set real values before deployment.

# --- Core ---
SPRING_PROFILES_ACTIVE=prod
JAVA_OPTS="-Xms128m -Xmx256m"

# --- Security ---
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRATION=86400000

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres

AUTH_DB_URL=jdbc:postgresql://postgres:5432/micropay_auth_db
WALLET_DB_URL=jdbc:postgresql://postgres:5432/micropay_wallet_db
PAYMENT_DB_URL=jdbc:postgresql://postgres:5432/micropay_payment_db
TRANSACTION_DB_URL=jdbc:postgresql://postgres:5432/micropay_transaction_db
NOTIFICATION_DB_URL=jdbc:postgresql://postgres:5432/micropay_notification_db

# --- Kafka ---
KAFKA_BROKER=kafka:29092
# For host access to Kafka (e.g. debugging from EC2 shell)
KAFKA_ADVERTISED_HOST=localhost

# --- Frontend / Gateway ---
# When using nginx container, set the Vite build to call `/api`
VITE_API_BASE_URL=/api
FRONTEND_URL=http://localhost

# --- Image / ECR ---
# ECR_REGISTRY example: 123456789012.dkr.ecr.ap-south-1.amazonaws.com
ECR_REGISTRY=local
IMAGE_TAG=latest

